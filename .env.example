# OpenTalon 环境变量配置示例
# 复制此文件为 .env 并修改相应值

# 安装目录
# INSTALL_DIR=/home/admin/projects/opentalon

# 代码源 (github 或 gitee)
# REPO_SOURCE=github

# Python 命令
# PYTHON_CMD=python3

# PIP 命令
# PIP_CMD=pip3

# LLM 配置 (可选，也可以通过网页配置)
# LLM_PROVIDER=moonshot
# LLM_API_KEY=sk-your-api-key
# LLM_BASE_URL=https://api.moonshot.cn/v1
# LLM_MODEL=kimi-latest

# Web 服务配置
# WEB_PORT=6767
# WEB_HOST=0.0.0.0

# 是否启用虚拟环境
# USE_VENV=true
